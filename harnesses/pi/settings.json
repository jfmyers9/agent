    "extensions/context-guard/index.ts",
    "extensions/exec-command/index.ts",
    "extensions/ask/index.ts",
    "extensions/clear.ts",
    "extensions/effort.ts",
    "extensions/prompt-storage/index.ts",
    "extensions/vim/index.ts",
    "extensions/skillful/index.ts",
    "extensions/system-prompt/index.ts",
    "extensions/token-burden/index.ts",
    "extensions/tui/index.ts",
    "extensions/spawn/index.ts",
    "extensions/fork-split.ts"
  ]
