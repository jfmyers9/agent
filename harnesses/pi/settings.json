{
  "defaultProvider": "openai-codex",
  "defaultThinkingLevel": "high",
  "defaultModel": "gpt-5.5",
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.4-mini"
  ],
  "skills": [
    "skills"
  ],
  "enableSkillCommands": true,
  "steeringMode": "all",
  "autoUpdate": true,
  "transport": "auto",
  "doubleEscapeAction": "tree",
  "treeFilterMode": "default",
  "quietStartup": true,
  "hideThinkingBlock": false,
  "editorPaddingX": 0,
  "terminal": {
    "clearOnShrink": false,
    "showTerminalProgress": false
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "lastChangelogVersion": "0.74.0",
  "packages": [
    "npm:pi-lens",
    {
      "source": "npm:@plannotator/pi-extension",
      "skills": []
    },
    "npm:@dreki-gg/pi-context7@0.1.9"
  ],
  "extensions": [
    "extensions/plannotator-events/index.ts",
    "extensions/agents-local/index.ts",
    "extensions/clear.ts",
    "extensions/effort.ts",
    "extensions/mac-system-theme.ts",
    "extensions/prompt-storage/index.ts",
    "extensions/vim/index.ts",
    "extensions/tasks/index.ts",
    "extensions/skillful/index.ts",
    "extensions/system-prompt/index.ts",
    "extensions/token-burden/index.ts",
    "extensions/tui/index.ts",
    "extensions/spawn/index.ts"
  ]
}
