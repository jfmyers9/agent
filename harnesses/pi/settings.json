{
  "defaultProvider": "openai",
  "theme": "dark",
  "defaultThinkingLevel": "high",
  "defaultModel": "gpt-5.6-luna",
  "enabledModels": [
    "openai/gpt-5.6-luna",
    "openai/gpt-5.6-terra",
    "openai/gpt-5.6-sol",
    "openai/gpt-5.5",
    "openai/gpt-5.4",
    "openai/gpt-5.4-mini",
    "anthropic/claude-opus-4-8",
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-haiku-4-5"
  ],
  "skills": [
    "skills"
